package lyc.compiler;import lyc.compiler.files.SymbolTableGenerator;import java_cup.runtime.*;import lyc.compiler.model.*;import java.util.*;class Parser;parser code {:    public SymbolTableGenerator symbolTable = new SymbolTableGenerator();:}// Terminalsterminal UMINUS;terminal ASSIG;terminal PLUS;terminal SUB;terminal MULT;terminal DIV;terminal OPEN_BRACKET;terminal CLOSE_BRACKET;terminal INTEGER_CONSTANT;terminal IDENTIFIER;terminal DOBLE_EQUAL, NOT_EQUAL, INIT, GREATER_THAN, LESS_THAN_EQUAL, ELSE, IF;terminal CLOSE_BRACE, COLON, SEMICOLON, OR, IN, WHILE;terminal STRING_CONSTANT, STRING, FLOAT, INT, BOOLEAN, READ;terminal LESS_THAN, NOT, AND, CLOSE_SQUARE_BRACKET, COMMA, OPEN_BRACE;terminal OPEN_SQUARE_BRACKET, LONG, FLOAT_CONSTANT, WRITE, GREATER_THAN_EQUAL;terminal DO, ENDWHILE;// Non Terminalsnon terminal assignment;non terminal expr, term, unary_expr, factor, expr_list;non terminal program, statements, statement;non terminal decl,var_decl;non terminal id_list;non terminal type;non terminal while, if, read, write, condition, simple_condition;non terminal special_cycle;// Precedenciaprecedence left OR;precedence left AND;precedence right NOT;precedence left PLUS, SUB;precedence left MULT, DIV;precedence right UMINUS;// Start Symbol Definitionstart with program;program ::= decl statements {: System.out.println("[RULE] program -> decl statements"); :} ;decl ::= INIT OPEN_BRACE var_decl CLOSE_BRACE {: System.out.println("[RULE] decl -> INIT { var_decl }"); :} ;statements ::= /* vacío */               {: System.out.println("[RULE] statements -> "); :}               | statements statement               {: System.out.println("[RULE] statements -> statements statement"); :} ;statement ::= assignment {: System.out.println("[RULE] statement -> assignment"); :}              | while {: System.out.println("[RULE] statement -> while"); :}              | if {: System.out.println("[RULE] statement -> if"); :}              | read {: System.out.println("[RULE] statement -> reader"); :}              | write {: System.out.println("[RULE] statement -> write"); :}              | special_cycle {: System.out.println("[RULE] statement -> special_cycle"); :};var_decl ::= id_list:l COLON type:t             {:                System.out.println("[RULE] var_decl -> id_list : type");                symbolTable.addVariables((List<Object>) l, (String) t);             :}           | id_list:l COLON type:t var_decl             {:                System.out.println("[RULE] var_decl -> id_list : type var_decl");                symbolTable.addVariables((List<Object>) l, (String) t);             :};id_list ::= IDENTIFIER:s              {:                 List<Object> list = new ArrayList<>();                 list.add(s);                 RESULT = list;              :}          | id_list:l COMMA IDENTIFIER:s              {:                 List<Object> list = (List<Object>) l;                 list.add(s);                 RESULT = list;              :};while ::= WHILE OPEN_BRACKET condition CLOSE_BRACKET OPEN_BRACE statements CLOSE_BRACE    {: System.out.println("[RULE] while -> WHILE( condition ) { statements }"); :} ;if ::=           IF OPEN_BRACKET condition CLOSE_BRACKET OPEN_BRACE statements CLOSE_BRACE ELSE OPEN_BRACE statements CLOSE_BRACE           {: System.out.println("[RULE] if -> IF( condition ) { statements } ELSE { statements }"); :}         | IF OPEN_BRACKET condition CLOSE_BRACKET OPEN_BRACE statements CLOSE_BRACE           {: System.out.println("[RULE] if -> IF( condition ) { statements }"); :};read ::= READ OPEN_BRACKET IDENTIFIER CLOSE_BRACKET         {: System.out.println("[RULE] reader -> read ( IDENTIFIER )"); :} ;write ::= WRITE OPEN_BRACKET expr CLOSE_BRACKET       {: System.out.println("[RULE] write -> write ( expr )"); :} ;assignment ::= IDENTIFIER ASSIG expr {: System.out.println("[RULE] assignment -> IDENTIFIER = expr"); :};expr ::= expr PLUS term       {: System.out.println("[RULE] expr -> expr + term"); :}       | expr SUB term       {: System.out.println("[RULE] expr -> expr - term"); :}       | term       {: System.out.println("[RULE] expr -> term"); :} ;term ::= term MULT unary_expr       {: System.out.println("[RULE] term -> term * unary_expr"); :};term ::= term DIV unary_expr       {: System.out.println("[RULE] term -> term / unary_expr"); :};term ::= unary_expr       {: System.out.println("[RULE] term -> unary_expr"); :};unary_expr ::= SUB factor             {: System.out.println("[RULE] unary_expr -> - factor"); :} %prec UMINUS             | PLUS factor             {: System.out.println("[RULE] unary_expr -> + factor"); :} %prec UMINUS             | factor             {: System.out.println("[RULE] unary_expr -> factor"); :} ;factor ::= IDENTIFIER:id         {: System.out.println("[RULE] factor -> IDENTIFIER"); :};factor ::= INTEGER_CONSTANT:i         {:            System.out.println("[RULE] factor -> INTEGER_CONSTANT");            symbolTable.addConstant(i, i);         :};factor ::= OPEN_BRACKET expr CLOSE_BRACKET {: System.out.println("[RULE] factor -> ( expr )"); :};factor ::= FLOAT_CONSTANT:f         {:            System.out.println("[RULE] factor -> FLOAT_CONSTANT");            symbolTable.addConstant(f, f);         :};factor ::= STRING_CONSTANT:s         {:            System.out.println("[RULE] factor -> STRING_CONSTANT");            symbolTable.addConstant(s, s);         :};factor ::= LONG OPEN_BRACKET OPEN_SQUARE_BRACKET expr_list CLOSE_SQUARE_BRACKET CLOSE_BRACKET         {: System.out.println("[RULE] factor -> long ( [ expr_list ] )"); :};condition ::= simple_condition              {: System.out.println("[RULE] condition -> simple_condition"); :}            | simple_condition AND simple_condition              {: System.out.println("[RULE] condition -> simple_condition AND simple_condition"); :}            | simple_condition OR simple_condition              {: System.out.println("[RULE] condition -> simple_condition OR simple_condition"); :}            | NOT simple_condition              {: System.out.println("[RULE] condition -> NOT simple_condition"); :};simple_condition ::= expr GREATER_THAN expr                     {: System.out.println("[RULE] simple_condition -> expr > expr"); :}                   | expr LESS_THAN expr                     {: System.out.println("[RULE] simple_condition -> expr < expr"); :}                   | expr LESS_THAN_EQUAL expr                     {: System.out.println("[RULE] simple_condition -> expr <= expr"); :}                   | expr GREATER_THAN_EQUAL expr                     {: System.out.println("[RULE] simple_condition -> expr >= expr"); :}                   | expr DOBLE_EQUAL expr                     {: System.out.println("[RULE] simple_condition -> expr == expr"); :}                   | expr NOT_EQUAL expr                     {: System.out.println("[RULE] simple_condition -> expr != expr"); :};expr_list ::= expr    {: System.out.println("[RULE] expr_list -> expr"); :}    | expr_list COMMA expr    {: System.out.println("[RULE] expr_list -> expr_list , expr"); :};special_cycle ::= WHILE IDENTIFIER IN OPEN_SQUARE_BRACKET expr_list CLOSE_SQUARE_BRACKET DO statements ENDWHILE    {: System.out.println("[RULE] special_cycle -> WHILE IDENTIFIER IN [ expr_list ] DO statements ENDWHILE"); :};type ::= INT     {: System.out.println("[RULE] type -> INT");     RESULT = "Int"; :}       | BOOLEAN {: System.out.println("[RULE] type -> BOOLEAN"); RESULT = "Boolean"; :}       | FLOAT   {: System.out.println("[RULE] type -> FLOAT");   RESULT = "Float"; :}       | STRING  {: System.out.println("[RULE] type -> STRING");  RESULT = "String"; :};